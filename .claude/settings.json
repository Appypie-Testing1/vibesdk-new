{
  "permissions": {
    "allow": [
      "Bash(bun run typecheck)",
      "Bash(bun run test*)",
      "Bash(bun run lint)",
      "Bash(bun run knip*)",
      "Bash(bun run build)",
      "Bash(bun run db:check)",
      "Bash(bun run db:generate)",
      "Bash(bun run db:migrate:local)",
      "Bash(git *)",
      "Bash(.claude/hooks/*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-context.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-references.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-guard.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-ts-violations.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop-review-hint.sh",
            "timeout": 3
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/hooks/statusline.sh",
    "refreshInterval": 30
  },
  "enabledPlugins": {
    "cloudflare@claude-plugins-official": true
  }
}
